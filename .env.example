# =============================================================================
# Verbal Confidence — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Shell variables already set (e.g. in a SLURM job) take precedence over .env.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Two storage roots
# -----------------------------------------------------------------------------

# EPHEMERAL_ROOT: Large, re-downloadable data.
#   HuggingFace model weights, dataset cache, pip/conda packages.
#   Use fast scratch storage. Safe to wipe — everything can be re-fetched.
#
#   HLR example : /scratch/mygroup/myuser
#   Local example: /tmp/vc_cache
EPHEMERAL_ROOT=/scratch/YOURGROUP/YOURUSER

# PERMANENT_ROOT: Important, irreplaceable outputs.
#   Experiment results and logs live here. Back this up.
#
#   HLR example : /home/myuser
#   Local example: /Users/yourname/research
PERMANENT_ROOT=/home/YOURUSER

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------

# HuggingFace read token — required for gated models (e.g. Gemma 3 27B).
# Create a token at https://huggingface.co/settings/tokens
# Then accept the Gemma licence at https://huggingface.co/google/gemma-3-27b-it
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Override the run subdirectory name (default: "default").
# In SLURM jobs this is set automatically to $SLURM_JOB_ID.
# RUN_NAME=my_experiment

# SLURM email notifications (optional, referenced in slurm/ scripts).
# SLURM_MAIL=you@example.com

# -----------------------------------------------------------------------------
# SLURM cluster settings
# -----------------------------------------------------------------------------

# Your SLURM account name (required on most clusters; check with `sacctmgr show user $USER`).
# Leave unset only if your cluster does not require --account.
SLURM_ACCOUNT=YOURACCOUNT

# Partition names (defaults match the job scripts, change to match your cluster).
# Check available partitions with `sinfo -s`.
SLURM_PARTITION=gpu
SLURM_TEST_PARTITION=test
